# systemd unit for the FastAPI backend. Install to /etc/systemd/system/nha-copilot.service
[Unit]
Description=NHA SHA Analytical Co-pilot backend
After=network.target

[Service]
User=nha
Group=nha
WorkingDirectory=/opt/nha-copilot/backend
EnvironmentFile=/etc/nha-copilot/env
ExecStart=/opt/nha-copilot/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
