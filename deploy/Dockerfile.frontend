# =============================================================================
# OPTIONAL: build + serve the frontend as a single container (nginx inside).
# Use this only if your internal setup runs Docker. Otherwise ignore this file
# and follow the plain "build + copy dist/" steps in deploy/SELF_HOSTING.md.
#
# Build (run from the repo root):
#   docker build -f deploy/Dockerfile.frontend \
#     --build-arg VITE_API_BASE=https://copilot-api.nha.internal \
#     --build-arg VITE_BASE=/ \
#     -t nha-copilot-frontend .
#
# Run (serves on http://<host>:8080):
#   docker run -d --name nha-copilot-frontend -p 8080:80 nha-copilot-frontend
# =============================================================================

# ---- Stage 1: build the static files ----
FROM node:20-alpine AS build
WORKDIR /app

# Build-time config (baked into the static bundle).
ARG VITE_API_BASE=""
ARG VITE_BASE="/"
ENV VITE_API_BASE=${VITE_API_BASE}
ENV VITE_BASE=${VITE_BASE}

# Install deps first (better layer caching).
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

# Build.
COPY frontend/ ./
RUN npm run build

# ---- Stage 2: serve with nginx ----
FROM nginx:1.27-alpine
# Minimal SPA-friendly nginx config (frontend-only; backend is a separate URL).
RUN printf 'server {\n\
    listen 80;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    location / { try_files $uri $uri/ /index.html; }\n\
    location /assets/ { expires 1y; add_header Cache-Control "public, immutable"; }\n\
}\n' > /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
