# Backend environment for the VM. Copy to /etc/nha-copilot/env and fill in.
# Keep this file readable ONLY by the service user:  chmod 600 /etc/nha-copilot/env

# --- BigQuery (no key file needed: the VM's attached service account is used) ---
GCP_PROJECT=nha-conversational-analytics
BQ_DATASET=nha_conversational_analytics
# ABDM table names default to the loaded names (see backend/app/config.py);
# only override here if yours differ, e.g. BQ_SCAN_SHARE_TABLE=scan_and_share
# Leave GOOGLE_CREDENTIALS_JSON unset so the app uses the VM's service account
# (grant that SA roles/bigquery.dataViewer + roles/bigquery.jobUser).
REFERENCE_DATA_DIR=reference

# --- OpenAI ---
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4.1

# --- Auth (PRODUCTION) ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRE_MINUTES=480
# Strong users; format user:password:role separated by ';'
# roles: viewer | analyst | senior_analyst | admin
APP_USERS=admin:REPLACE_STRONG_PW:admin;analyst:REPLACE_STRONG_PW:analyst

# --- CORS: lock to the GitHub Pages origin (no trailing slash) ---
CORS_ORIGINS=https://zerobug-mohit.github.io
