# ---- Google BigQuery ----
# GCP project that holds the dataset
GCP_PROJECT=nha-conversational-analytics
# BigQuery dataset (schema) containing the tables
BQ_DATASET=nha_conversational_analytics
# ABDM table names — only set these if your loaded table names differ from the
# defaults below (defaults match backend/app/config.py).
# BQ_FACILITY_REGISTRY_TABLE=health_facility_registry
# BQ_PROFESSIONALS_REGISTRY_TABLE=health_professionals_registry
# BQ_TOP_INDICATORS_TABLE=healthid_top_indicators
# BQ_LINKED_TREND_TABLE=healthid_linked_trend
# BQ_LINKED_FACILITY_TABLE=linked_facility
# BQ_SCAN_SHARE_TABLE=scan_and_share
# BQ_SCAN_PAY_TABLE=scan_pay_count
# BQ_STATE_DISTRICT_MASTER_TABLE=state_district_master
# BQ_BRIDGE_INTEGRATOR_TABLE=integrator_detail
# Path to the service account JSON key. Grant it ONLY:
#   roles/bigquery.dataViewer  +  roles/bigquery.jobUser
# so read-only is enforced at the IAM level (safety layer 3).
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
# Safety cap: max bytes a single query is allowed to bill (default 2 GB).
BQ_MAX_BYTES_BILLED=2147483648

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# ---- Auth / JWT ----
# Generate a strong random secret for production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ---- App ----
# Comma-separated allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Path to the reference data folder (lgd_master.xlsx).
# Bundled in backend/reference so the repo is self-contained.
REFERENCE_DATA_DIR=reference

# Prototype seed-user passwords (username:password:role). Change for any real use.
# Format handled in app/auth/users.py; these are the defaults if unset.
